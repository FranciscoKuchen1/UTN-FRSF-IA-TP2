# ─── LLM ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=tu_api_key_de_google_ai_studio
LLM_MODEL=gemini-2.0-flash

# ─── RAG (Supabase pgvector) ─────────────────────────────────────────────────
# URL y clave anónima del proyecto en https://app.supabase.com
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # clave "anon" (public)

# Umbral de similitud coseno para el RAG (0.0 – 1.0); más alto = más estricto
SIMILARITY_THRESHOLD=0.7

# ─── Auth (Supabase Auth) ────────────────────────────────────────────────────
# La misma SUPABASE_URL y SUPABASE_KEY de arriba se usan para Auth.
# El JWT que emite Supabase se valida a través del cliente supabase-py;
# NO se necesita configurar un secret adicional acá.

# ─── Memoria ─────────────────────────────────────────────────────────────────
# "memory" → sin Redis (perfil se pierde al reiniciar el backend)
# "redis"  → requiere REDIS_URL válida (recomendado para coloquio/producción)
MEMORY_BACKEND=memory
REDIS_URL=rediss://default:password@host:port   # solo si MEMORY_BACKEND=redis

# ─── Agent ───────────────────────────────────────────────────────────────────
MAX_REACT_ITERATIONS=5

# ─── Observabilidad (Langfuse) ───────────────────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://us.cloud.langfuse.com

# ─── CORS / Frontend ─────────────────────────────────────────────────────────
# Origen permitido para el frontend React (Vite: 5173, CRA: 3000)
FRONTEND_ORIGIN=http://localhost:5173
