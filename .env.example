# LLM (Groq)
GROQ_API_KEY=tu_api_key_de_groq
LLM_MODEL=qwen/qwen3-32b

# RAG: Supabase pgvector
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=tu_clave_anon_o_service_role
SIMILARITY_THRESHOLD=0.7

# Embeddings semanticos (si falta, el retriever usa busqueda full-text)
NOMIC_API_KEY=tu_api_key_de_nomic
NOMIC_EMBEDDING_MODEL=nomic-embed-text-v1.5

# Memoria
MEMORY_BACKEND=memory
REDIS_URL=rediss://default:password@host:port

# Agente y derivaciones
MAX_REACT_ITERATIONS=5
ACCOUNTANT_WEBHOOK_URL=
# ESCALATION_LOG_PATH=data/escalations.jsonl

# Observabilidad (opcional)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://us.cloud.langfuse.com

# API / Frontend
FRONTEND_ORIGIN=http://localhost:5173
MAX_UPLOAD_SIZE_MB=10
